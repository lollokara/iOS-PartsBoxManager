PARTSBOX_API_KEY=partsboxapi_replace_with_local_key
NEXAR_CLIENT_ID=your_nexar_client_id
NEXAR_CLIENT_SECRET=your_nexar_client_secret
# Optional fallback/debug token. Runtime client credentials are preferred.
NEXAR_ACCESS_TOKEN=
DIGIKEY_CLIENT_ID=your_digikey_client_id
DIGIKEY_CLIENT_SECRET=your_digikey_client_secret
PARTSBOX_HELPER_PORT=39117
LABEL_OUTPUT_DIR=./out/labels

# Passive Library Browser
LIBRARY_PORT=39200
LIBRARY_HOST=0.0.0.0
LIBRARY_DATA_DIR=./data
LIBRARY_WEB_ROOT=./web/dist
LIBRARY_SYNC_INTERVAL_MS=1800000
PENDING_SYNC_INTERVAL_MS=60000

# Optional single-user auth for the library server.
# When AUTH_PASSWORD_HASH is set, AUTH_ENABLED defaults to true.
# Generate a random password and update .env with: npm run auth:reset
# Generate a hash with: printf '%s' 'your-password' | npm run auth:hash
# Use a long random secret here; bearer tokens are HMAC-signed and the app
# does not depend on app-managed TLS or secure cookies.
AUTH_ENABLED=
AUTH_PASSWORD_HASH=
AUTH_TOKEN_SECRET=
# 315360000 = 10 years. Use a shorter value if you want sessions to expire.
AUTH_TOKEN_TTL_SECONDS=315360000
AUTH_ALLOW_LOCAL_BYPASS=false
